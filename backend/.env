# .env — NEVER commit this file to GitHub
# This file holds all secrets and config values
# process.env.PORT reads PORT from here in your code

PORT=5000

# Get this from MongoDB Atlas → Connect → Drivers
# Replace <username>, <password>, <clustername> with yours
MONGO_URI=mongodb+srv://nehaguptang1108_db_user:mongoDBnewpassword@cluster0.pgjteap.mongodb.net/backenddb
# mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/expensetracker?retryWrites=true&w=majority

# JWT_SECRET = a long random string. Used to sign tokens.
# Think of it like a wax seal — only you have this seal.
# Make it at least 32 characters long. Never share it.
JWT_SECRET=expense_tracker_super_secret_jwt_key_2025_do_not_share

# JWT_EXPIRE = how long the login token lasts before expiring
JWT_EXPIRE=7d

# NODE_ENV = tells the app if it's in development or production
NODE_ENV=development

# EMAIL SETTINGS — for sending OTP emails via Gmail
# Go to Google Account → Security → App Passwords → create one
# Use that 16-character app password here (NOT your Gmail password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=yourname@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# OTP_EXPIRE_MINUTES = how many minutes before OTP expires
OTP_EXPIRE_MINUTES=5



